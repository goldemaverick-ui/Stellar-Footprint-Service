{
  "name": "stellar-footprint-service",
  "version": "1.0.0",
  "description": "Stellar transaction footprint simulation service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:stop": "pm2 stop stellar-footprint-service",
    "pm2:delete": "pm2 delete stellar-footprint-service",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "solhint": "solhint 'contracts/**/*.sol'",
    "prepare": "husky"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "solhint": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "validate-branch-name": "^1.3.2"
  },
  "validate-branch-name": {
    "pattern": "^(main|develop|live)$|^(feature|fix|refactor|hotfix|release|conflict)/.+$",
    "errorMsg": "Branch name must be: main | develop | live\nOr prefixed with: feature/ | fix/ | refactor/ | hotfix/ | release/ | conflict/\nExample: feature/my-new-feature"
  }
}
